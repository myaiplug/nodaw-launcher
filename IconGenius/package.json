{
  "name": "img2ico",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "High Quality Image to ICO Converter",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "wait-on tcp:5173 && electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.img2ico.app",
    "productName": "Img 2 Ico",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "img2ico.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "img2ico.ico"
    }
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "clsx": "^2.0.0",
    "lamejs": "^1.2.1",
    "lucide-react": "^0.300.0",
    "png-to-ico": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.5",
    "wait-on": "^7.0.0"
  }
}
