{
  "name": "nodaw-studio",
  "private": true,
  "version": "1.2.0",
  "description": "Professional Audio Suite - All-in-One Offline Audio Tools",
  "author": "b33zy",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron . --user-data-dir=\"%TEMP%\\nodaw-user\" --disk-cache-dir=\"%TEMP%\\nodaw-cache\"",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron\"",
    "prebuild:subapps": "node scripts/build-subapps.mjs",
    "electron:build": "npm run build && npm run prebuild:subapps && electron-builder",
    "electron:build:win": "npm run build && npm run prebuild:subapps && electron-builder --win",
    "electron:build:mac": "npm run build && npm run prebuild:subapps && electron-builder --mac",
    "electron:build:linux": "npm run build && npm run prebuild:subapps && electron-builder --linux",
    "electron:build:all": "npm run build && npm run prebuild:subapps && electron-builder --win --mac --linux",
    "electron:build:offline": "npm run build && npm run prebuild:subapps && electron-builder --win --config.nsis.oneClick=false"
  },
  "build": {
    "appId": "com.nodaw.studio",
    "productName": "NoDAW Studio Suite",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "nodaw.png",
      "nodaw.ico"
    ],
    "extraResources": [
      {
        "from": "bundled-apps/TrimIt",
        "to": "apps/TrimIt",
        "filter": ["**/*"]
      },
      {
        "from": "bundled-apps/IconGenius",
        "to": "apps/IconGenius",
        "filter": ["**/*"]
      },
      {
        "from": "bundled-apps/StemSplit",
        "to": "apps/StemSplit",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/ffmpeg*",
      "**/python*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "nodaw.ico",
      "legalTrademarks": "NoDAW Studios"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "nodaw.png",
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "backgroundColor": "#0f172a",
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "nodaw.png",
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "nodaw.ico",
      "uninstallerIcon": "nodaw.ico",
      "installerHeaderIcon": "nodaw.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoDAW Studio",
      "license": "LICENSE",
      "uninstallDisplayName": "NoDAW Studio Suite"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "framer-motion": "^12.38.0",
    "lamejs": "^1.2.1",
    "libflacjs": "^5.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.183.2",
    "web-audio-beat-detector": "^8.2.35",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.7.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.3"
  }
}
